{
  "manifest_version": 3,
  "name": "AI Live Viewer",
  "version": "1.0",
  "description": "Live stream AI responses into a standalone, feature-rich, and editable window.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "*://*.deepseek.com/*",
    "*://chatgpt.com/*",
    "*://gemini.google.com/*",
    "*://claude.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.deepseek.com/*",
        "*://chatgpt.com/*",
        "*://gemini.google.com/*",
        "*://claude.ai/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open AI Live Viewer"
  },
  "icons": {
    "128": "icon.png"
  }
}
